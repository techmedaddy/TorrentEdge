# .env.prod.example — copy to .env.prod and fill in real values
# cp .env.prod.example .env.prod

# ── MongoDB ───────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_me_strong_password

# ── Backend ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3029

# Full URI (auto-constructed in docker-compose.prod.yml, but override here if needed)
# MONGODB_URI=mongodb://root:change_me@mongodb:27017/torrentedge?authSource=admin

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── App secrets ───────────────────────────────────────────────────────
# JWT_SECRET=change_me_random_256bit_string
# SESSION_SECRET=change_me_random_256bit_string

# ── Optional: Gemini / AI ─────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Domain (for future TLS/HTTPS setup) ──────────────────────────────
# DOMAIN=your-domain.com
