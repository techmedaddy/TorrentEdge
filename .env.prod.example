# .env.prod.example — PUBLIC CONFIG TEMPLATE
# Copy this to .env.prod and fill in real secrets.

# ── MongoDB ───────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=REQUIRED

# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3029
MONGODB_URI=mongodb://root:MONGO_ROOT_PASSWORD@mongodb:27017/torrentedge?authSource=admin
JWT_SECRET=REQUIRED_STRONG_RANDOM_STRING

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REQUIRED
GOOGLE_CLIENT_SECRET=REQUIRED
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# ── Frontend / CORS ───────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# ── Infrastructure ───────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
