# TorrentEdge Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3029
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/torrentedge

# CORS
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# JWT Authentication
# IMPORTANT: Generate a strong random secret for production
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Google OAuth (optional - leave empty to disable)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3029/auth/google/callback

# Torrent Engine
DOWNLOAD_PATH=./downloads

# Max file size for create-from-file uploads (bytes). Default: 2GB
# Examples: 104857600 = 100MB, 1073741824 = 1GB, 2147483648 = 2GB
MAX_SEED_FILE_SIZE=2147483648
TORRENT_PORT=6881
MAX_ACTIVE_TORRENTS=5
MAX_CONCURRENT=3

# Kafka (optional - for event streaming)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=torrentedge
KAFKA_TOPIC=torrent-events

# Rate Limiting (bytes per second, 0 = unlimited)
GLOBAL_DOWNLOAD_LIMIT=0
GLOBAL_UPLOAD_LIMIT=0

# State Persistence
STATE_DIR=./data/state
STATE_SAVE_INTERVAL=30000
AUTO_RESUME=true
VERIFY_ON_RESUME=false
